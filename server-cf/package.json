{
  "name": "matbil-code-api-cf",
  "version": "1.0.0",
  "description": "MatBil kitap kodu API — Cloudflare Workers + D1 sürümü",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:local:migrate": "wrangler d1 migrations apply matbil_codes --local",
    "db:prod:migrate": "wrangler d1 migrations apply matbil_codes --remote",
    "db:generate-codes": "wrangler d1 execute matbil_codes --remote --file=./migrations/0002_seed_codes.sql"
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250117.0",
    "typescript": "^5.7.2",
    "wrangler": "^3.100.0"
  }
}
