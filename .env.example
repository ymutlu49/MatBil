# MatBil Ön-Yüz Ortam Değişkenleri
# Bu dosyayı .env olarak kopyala, değerleri düzenle.

# Backend kod doğrulama API'si (boş bırakılırsa lokal DEMO_CODES kullanılır)
# Örnekler:
#   Dev:  VITE_CODE_API_URL=http://localhost:3001
#   Prod: VITE_CODE_API_URL=https://api.diskalkuli.com
VITE_CODE_API_URL=

# Sentry DSN (opsiyonel — en güçlü telemetri, @sentry/react kullanır).
# Tanımlıysa main.jsx'te initTelemetry() Sentry'yi init eder, ErrorBoundary
# hataları Sentry'ye gönderir. IP/PII gönderilmez, session replay kapalı.
# Örnek: VITE_SENTRY_DSN=https://abc@o123.ingest.sentry.io/456
VITE_SENTRY_DSN=

# Custom hata endpoint'i (Sentry yoksa fallback).
# Tanımlıysa ErrorBoundary hata JSON'unu POST eder.
# Örnek: VITE_ERROR_REPORT_URL=https://api.diskalkuli.com/errors
VITE_ERROR_REPORT_URL=
